FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY server/go.mod server/go.sum ./
RUN go mod download

COPY server/ ./

RUN CGO_ENABLED=0 GOOS=linux go build -o /trafficgen ./cmd/trafficgen

FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /trafficgen /usr/local/bin/trafficgen

ENTRYPOINT ["trafficgen"]
